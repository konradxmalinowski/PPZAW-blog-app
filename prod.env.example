# Production environment variables template.
# Copy values to the Render dashboard (Environment tab of your web service).
# Never commit the real prod.env — it is in .gitignore.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=devlog.settings.production
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-50
DEBUG=False

# ── Hosts & URLs ──────────────────────────────────────────────────────────────
ALLOWED_HOSTS=.onrender.com,your-app-name.onrender.com
SITE_URL=https://your-app-name.onrender.com

# ── Database (Render injects this automatically when you link a PostgreSQL DB) ─
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Superuser (created automatically on first migrate) ────────────────────────
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=your@email.com
SUPERUSER_PASSWORD=change-me-strong-password

# ── Email (Gmail SMTP + App Password) ─────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=DevLog <your@gmail.com>

# ── Optional ──────────────────────────────────────────────────────────────────
SITE_DEFAULT_OG_IMAGE=
